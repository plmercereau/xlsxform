{
	"name": "xlsxform-monorepo",
	"private": true,
	"description": "TypeScript port of pyxform - converts XLSForms to ODK XForms",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/plmercereau/xlsxform.git"
	},
	"scripts": {
		"dev": "pnpm --filter xlsxform run build && pnpm -r --parallel run dev",
		"build": "pnpm -r run build",
		"test": "pnpm -r run test",
		"test:e2e": "pnpm --filter demo run e2e",
		"coverage": "pnpm --filter xlsxform run coverage",
		"lint": "biome check xlsxform demo",
		"lint:fix": "biome check --write xlsxform demo",
		"format": "biome check --write xlsxform demo",
		"typecheck": "pnpm --filter xlsxform run build && pnpm -r run typecheck",
		"prepare": "lefthook install"
	},
	"packageManager": "pnpm@10.13.1",
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"lefthook": "^2.1.6"
	}
}