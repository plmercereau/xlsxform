{
	"name": "xlsxform",
	"version": "0.0.1",
	"description": "TypeScript port of pyxform - converts XLSForms to ODK XForms",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/plmercereau/xlsxform.git",
		"directory": "xlsxform"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"prebuild": "rm -rf dist",
		"build": "tsc -p tsconfig.src.json",
		"dev": "tsc -p tsconfig.src.json --watch --preserveWatchOutput",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"lint": "biome check src tests",
		"lint:fix": "biome check --write src tests",
		"format": "biome check --write src tests",
		"typecheck": "tsc --noEmit -p tsconfig.src.json && tsc --noEmit -p tsconfig.check.json",
		"knip": "knip"
	},
	"peerDependencies": {
		"xlsx": ">=0.18.0"
	},
	"peerDependenciesMeta": {
		"xlsx": {
			"optional": true
		}
	},
	"dependencies": {
		"@xmldom/xmldom": "^0.9.8",
		"language-tags": "^2.1.0"
	},
	"devDependencies": {
		"@types/adm-zip": "^0.5.8",
		"@types/language-tags": "^1.0.4",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^3.2.4",
		"adm-zip": "^0.5.17",
		"knip": "^6.4.1",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
		"xpath": "^0.0.34"
	}
}
